{
  "schemaVersion": "1.0.0",
  "artifact": "ui-design",
  "mode": "hifi",
  "feature": "Codex Lite",
  "updatedAt": "2026-06-11T00:00:00Z",
  "tokens": {
    "colors": {
      "primary": "#0F766E",
      "primaryHover": "#0D9488",
      "primaryActive": "#115E59",
