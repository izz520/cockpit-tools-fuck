      "border": "#E5E7EB",
      "borderStrong": "#D1D5DB",
      "background": "#F3F4F6",
      "surface": "#FFFFFF",
      "surfaceMuted": "#F9FAFB",
      "success": "#059669",
      "successSoft": "#D1FAE5",
      "warning": "#D97706",
      "warningSoft": "#FEF3C7",
      "error": "#DC2626",
      "errorSoft": "#FEE2E2",
      "info": "#2563EB",
      "infoSoft": "#DBEAFE"
    },
    "typography": {
      "fontSans": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, PingFang SC, Microsoft YaHei, sans-serif",
      "fontMono": "SF Mono, Cascadia Code, JetBrains Mono, monospace",
      "pageTitle": { "fontSize": 22, "lineHeight": 30, "fontWeight": 650 },
      "sectionTitle": { "fontSize": 16, "lineHeight": 24, "fontWeight": 650 },
      "rowTitle": { "fontSize": 14, "lineHeight": 20, "fontWeight": 600 },
      "body": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400 },
      "caption": { "fontSize": 12, "lineHeight": 16, "fontWeight": 400 },
      "mono": { "fontSize": 12, "lineHeight": 18, "fontWeight": 400 }
    },
